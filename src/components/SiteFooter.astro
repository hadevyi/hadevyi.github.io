---
import SocialIconLinks from './SocialIconLinks.astro';
import { siteMeta, socialLinks } from '../data/site';

const i18nText = (ko: string, en: string) => ({
  'data-i18n-ko': ko,
  'data-i18n-en': en
});

const ecosystemLinks = [
  {
    href: 'https://hadevyi.github.io/',
    labelKo: '공식 홈페이지',
    labelEn: 'Official Website'
  },
  {
    href: 'https://hadevyi.github.io/resume/',
    labelKo: '이력서',
    labelEn: 'Resume'
  },
  {
    href: 'https://hadevyi.github.io/portfolio/',
    labelKo: '포트폴리오',
    labelEn: 'Portfolio'
  },
  {
    href: 'https://hadevyi.github.io/experience/',
    labelKo: '경험 정리',
    labelEn: 'Experience'
  },
  {
    href: 'https://hadevyi.github.io/blog/',
    labelKo: '블로그',
    labelEn: 'Blog'
  }
] as const;

const contactEmail = 'hadevyi@gmail.com';
const contactLinks = [{ label: 'Email', href: `mailto:${contactEmail}` }, ...socialLinks] as const;
const brandLabel = {
  ko: '당현아 공식 홈페이지',
  en: 'Dang Hyeona Official Website'
} as const;
const usageNotice = {
  ko: '본 사이트는 정상적인 검색 엔진의 공개 페이지 색인을 허용합니다.\n다만 별도 허가 없는 대량 크롤링, 무단 수집, 복제, 재배포, 재사용, 사칭 및 허위 사용은 금합니다.\n위반 시 민형사상 법적 조치를 진행할 수 있습니다.',
  en: 'This site allows public indexing by standard search engines.\nHowever, bulk crawling, unauthorized collection, copying, redistribution, reuse, impersonation, or false use without permission is prohibited.\nViolations may result in civil or criminal legal action.'
} as const;
const analyticsNotice = {
  ko: '본 사이트는 서비스 개선과 방문 통계 확인을 위해 Google Analytics를 사용합니다.\nGoogle Analytics는 방문 페이지, 접속 환경, 대략적인 지역 정보 등 비식별 분석 데이터를 수집할 수 있습니다.\n수집된 데이터는 사이트 이용 현황을 파악하고 콘텐츠와 사용성을 개선하는 목적으로만 활용됩니다.',
  en: 'This site uses Google Analytics to improve the service and review visit statistics.\nGoogle Analytics may collect non-identifying analytics data such as visited pages, access environment, and approximate location information.\nCollected data is used only to understand site usage and improve content and usability.'
} as const;
const copyrightNotice = '© 2026 Dang Hyeona. All rights reserved.';
const usageNoticeLabel = {
  ko: '이용 및 저작권 안내',
  en: 'Usage and copyright notice'
} as const;
const analyticsNoticeLabel = {
  ko: '분석 도구 안내',
  en: 'Analytics notice'
} as const;
---

<footer class="site-footer">
  <div class="mx-auto flex w-full max-w-[62rem] flex-col gap-2 px-5 py-4 sm:px-8 lg:px-10">
    <div class="flex flex-col gap-1.5 md:flex-row md:items-center md:justify-between">
      <div class="type-caption flex flex-wrap items-center gap-x-3 gap-y-1.5 text-ink/55">
        <p class="font-medium text-ink/78" {...i18nText(brandLabel.ko, brandLabel.en)}>
          {brandLabel.ko}
        </p>
        <SocialIconLinks links={contactLinks} compact={true} />
      </div>

      <nav class="type-caption flex flex-wrap gap-x-4 gap-y-1" aria-label="Hadevyi 사이트 링크">
        {
          ecosystemLinks.map((item) => {
            const isCurrent = item.href === siteMeta.siteUrl;

            return (
              <a
                href={item.href}
                aria-current={isCurrent ? 'page' : undefined}
                class:list={[isCurrent ? 'footer-inline-link-current' : 'footer-inline-link']}
              >
                <span {...i18nText(item.labelKo, item.labelEn)}>{item.labelKo}</span>
              </a>
            );
          })
        }
      </nav>
    </div>

    <div class="footer-legal type-micro border-t border-ink/10 pt-2 text-ink/36">
      <p>{copyrightNotice}</p>
      <div class="footer-legal-notices">
        <details class="footer-legal-notice">
          <summary {...i18nText(usageNoticeLabel.ko, usageNoticeLabel.en)}>
            {usageNoticeLabel.ko}
          </summary>
          <p {...i18nText(usageNotice.ko, usageNotice.en)}>
            {usageNotice.ko}
          </p>
        </details>
        <span class="footer-legal-separator" aria-hidden="true">|</span>
        <details class="footer-legal-notice">
          <summary {...i18nText(analyticsNoticeLabel.ko, analyticsNoticeLabel.en)}>
            {analyticsNoticeLabel.ko}
          </summary>
          <p {...i18nText(analyticsNotice.ko, analyticsNotice.en)}>
            {analyticsNotice.ko}
          </p>
        </details>
      </div>
    </div>
  </div>
</footer>

<script>
  document.querySelectorAll('.footer-legal-notices').forEach((group) => {
    group.querySelectorAll('details').forEach((details) => {
      details.addEventListener('toggle', () => {
        if (!details.open) return;

        group.querySelectorAll('details').forEach((item) => {
          if (item !== details) item.removeAttribute('open');
        });

        requestAnimationFrame(() => {
          const target = details.querySelector('p') ?? details;
          const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

          target.scrollIntoView({
            block: 'end',
            inline: 'nearest',
            behavior: prefersReducedMotion ? 'auto' : 'smooth'
          });
        });
      });
    });
  });
</script>
