                            <svg viewBox="0 0 24 24" aria-hidden="true" class="size-4 fill-current">
                              <path d="M5.15 8.77H2.3V21h2.85V8.77ZM5.4 4.93A1.65 1.65 0 1 0 2.1 4.9a1.65 1.65 0 0 0 3.3.03ZM21.9 14.3c0-3.7-1.98-5.42-4.62-5.42-2.13 0-3.08 1.17-3.62 1.99v-2.1h-2.85c.04.9 0 12.23 0 12.23h2.85v-6.83c0-.36.03-.73.14-.99.29-.73.96-1.49 2.08-1.49 1.47 0 2.05 1.12 2.05 2.76V21h3.97v-6.7Z" />
                            </svg>
