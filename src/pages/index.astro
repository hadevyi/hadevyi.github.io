---
import BaseLayout from '../layouts/BaseLayout.astro';

const profileImage = '/images/dang-hyeona-profile.png';

const text = (ko: string, en: string) => ({ ko, en });
const i18nText = (ko: string, en: string) => ({
  'data-i18n-ko': ko,
  'data-i18n-en': en
});
const i18nAttr = (attr: string, ko: string, en: string) => ({
  'data-i18n-attr': attr,
  'data-i18n-ko': ko,
  'data-i18n-en': en
});

const hero = {
  eyebrow: text('공유의 가치를 추구하는 개발자', 'A Developer Who Values Sharing'),
  title: text('당현아', 'Dang Hyeona'),
  paragraphs: [
    {
      lines: [
        text(
          '다양한 관점을 연결하며 팀의 흐름을 만듭니다.',
          'I connect diverse perspectives and help teams work together smoothly.'
        )
      ]
    },
    {
      lines: [
        text(
          '기록과 공유로 스스로를 점검하고',
          'Through writing and sharing, I reflect on my work'
        ),
        text(
          '함께 성장하는 분위기를 만듭니다.',
          'and help foster a culture of growth.'
        )
      ]
    }
  ],
  activities: [
    { icon: 'code', label: text('개발', 'Development') },
    { icon: 'book', label: text('개발교육', 'Education') },
    { icon: 'note', label: text('기록', 'Writing') },
    { icon: 'nodes', label: text('공유', 'Sharing') },
    { icon: 'heart', label: text('재능기부', 'Skills Volunteering') }
  ]
} as const;

const brandingReasons = [
  {
    number: '01',
    title: text('나를 더 잘 표현하기 위해', 'To Express Myself More Clearly'),
    paragraphs: [
      text(
        '개발자로서의 저는 완성된 결과보다 그 과정에서 어떤 선택을 했는지에 더 잘 드러난다고 생각합니다.',
        'I believe who I am as a developer is revealed not only in the final result, but in the choices I make throughout the process.'
      ),
      text(
        '그래서 생각의 흐름과 판단의 기준을 기록하며, 저를 더 선명하게 설명할 수 있는 공간을 만들고 싶었습니다.',
        'That is why I wanted to create a space where I can record my thought process and decision-making criteria more clearly.'
      )
    ]
  },
  {
    number: '02',
    title: text(
      '나에게도 누군가에게도\n자신감과 자극이 되도록',
      'To Build Confidence\nand Spark Momentum for Myself and Others'
    ),
    paragraphs: [
      text(
        '기록은 나에게 다시 꺼내볼 수 있는 기준이 되고, 다음 선택을 위한 자신감이 됩니다.',
        'My records become reference points I can return to, and confidence for my next decisions.'
      ),
      text(
        '동시에 누군가에게는 먼저 지나간 사람의 흔적으로 남아, 새로운 시도를 시작하는 작은 자극이 되기를 바랍니다.',
        'At the same time, I hope they remain as traces left by someone a few steps ahead and become a small spark for someone else to try something new.'
      )
    ]
  }
] as const;

const pathwaySection = {
  eyebrow: 'EXPLORE',
  title: text(
    '필요한 맥락에 따라 나누어 정리했습니다',
    'Organized by Context'
  ),
  titleLines: [
    text('필요한 맥락에 따라', 'Organized by'),
    text('나누어 정리했습니다', 'Context')
  ],
  description: text(
    '필요한 맥락에 따라 이력서, 포트폴리오, 경험정리, 블로그를 살펴볼 수 있습니다.',
    'Explore my resume, portfolio, experience archive, and blog depending on the context you need.'
  ),
  descriptionLines: [
    text('필요한 맥락에 따라', 'Explore my resume, portfolio,'),
    text('이력서, 포트폴리오, 경험정리, 블로그를', 'experience archive, and blog'),
    text('살펴볼 수 있습니다.', 'depending on the context you need.')
  ],
  note: text(
    '저의 경험과 기록은 서로 연결되어 있습니다. 관심 있는 주제부터 자유롭게 살펴보세요.',
    'My experiences and records are connected. Feel free to start with the topic you are most interested in.'
  )
} as const;

const pathwayItems = [
  {
    number: '01',
    href: '/resume/',
    icon: 'resume',
    label: text('이력서', 'Resume'),
    description: text('경력과 현재 집중 영역', 'Career summary and current focus'),
    disabled: false,
    status: undefined
  },
  {
    number: '02',
    href: '/portfolio/',
    icon: 'portfolio',
    label: text('포트폴리오', 'Portfolio'),
    description: text('프로젝트와 선택의 과정', 'Projects and the choices behind them'),
    disabled: true,
    status: text('준비 중', 'Coming soon')
  },
  {
    number: '03',
    href: '/experience/',
    icon: 'experience',
    label: text('경험정리', 'Experience'),
    description: text('성장 흐름과 경험의 기록', 'Growth path and experience notes'),
    disabled: false,
    status: undefined
  },
  {
    number: '04',
    href: '/blog/',
    icon: 'blog',
    label: text('블로그', 'Blog'),
    description: text('생각과 기술 메모', 'Thoughts and technical notes'),
    disabled: false,
    status: undefined
  }
] as const;

const resumeOptions = [
  {
    type: 'developer',
    role: text('개발자', 'Developer'),
    options: [
      { href: '/resume/ko/', language: 'ko', label: text('국문', 'KO') },
      { href: '/resume/en/', language: 'en', label: text('영문', 'EN') }
    ]
  },
  {
    type: 'instructor',
    role: text('강사', 'Instructor'),
    options: [
      { href: '/resume/instructor/ko/', language: 'ko', label: text('국문', 'KO') },
      { href: '/resume/instructor/en/', language: 'en', label: text('영문', 'EN') }
    ]
  }
] as const;

const contactSection = {
  eyebrow: 'CONTACT',
  titleLines: [
    text(
      '궁금한 점이나',
      'If you have a question'
    ),
    text('이어가고 싶은 이야기가 있다면', "or something you'd like to talk about,"),
    text('편히 연락주세요.', 'feel free to reach out.')
  ],
  email: 'hadevyi@gmail.com',
  notes: [
    text(
      '가장 빠르게 확인하는 연락 채널은 Email입니다.',
      'Email is the fastest way to reach me.'
    ),
    text(
      '작업 기록과 글은 GitHub와 Blog에 차곡차곡 남기고 있습니다.',
      'GitHub and Blog are where I keep my work logs and writing.'
    )
  ]
} as const;

const contactLinks = [
  {
    href: `mailto:${contactSection.email}`,
    external: false,
    icon: 'email',
    label: text('Email', 'Email'),
    description: text('메일로 연락', 'Fastest way to reach me')
  },
  {
    href: 'https://github.com/hadevyi',
    external: true,
    icon: 'github',
    label: text('GitHub', 'GitHub'),
    description: text('작업 기록과 저장소', 'Work logs and repositories')
  },
  {
    href: 'https://www.linkedin.com/in/hadevyi/',
    external: true,
    icon: 'linkedin',
    label: text('LinkedIn', 'LinkedIn'),
    description: text('커리어 프로필', 'Career profile')
  },
  {
    href: '/blog/',
    external: false,
    icon: 'blog',
    label: text('Blog', 'Blog'),
    description: text('글과 기술 메모', 'Writing and technical notes')
  }
] as const;
---

<BaseLayout showHeader={false} mainClass="!max-w-none !px-0 !pb-0">
  <div class="w-full">
    <section class="flex min-h-[88svh] items-center md:min-h-[92svh]">
      <div class="mx-auto w-full max-w-6xl px-5 py-10 sm:px-10 sm:py-12 md:px-12 md:py-14 lg:px-20 xl:px-24">
        <div class="border-y [border-color:var(--theme-border)]">
          <div class="grid items-end gap-7 py-8 md:grid-cols-[minmax(0,1.02fr)_minmax(13rem,0.66fr)] md:gap-10 md:py-10 lg:gap-14">
          <div class="space-y-4 pb-1 sm:space-y-5 md:pb-6">
            <div class="h-1 w-16 rounded-full [background-color:var(--theme-accent-mark)]"></div>
            <p
              class="type-body font-medium [color:var(--theme-ink-muted)]"
              {...i18nText(hero.eyebrow.ko, hero.eyebrow.en)}
            >
              {hero.eyebrow.ko}
            </p>
            <h1
              class="type-display [color:var(--theme-ink)]"
              {...i18nText(hero.title.ko, hero.title.en)}
            >
              {hero.title.ko}
            </h1>

            <div class="type-body max-w-xl space-y-2 pt-1 [word-break:keep-all] [color:var(--theme-ink-muted)] sm:pt-2">
              {
                hero.paragraphs.map((paragraph) => (
                  <p>
                    {
                      paragraph.lines.map((line, index) => (
                        <>
                          <span class="block sm:inline" {...i18nText(line.ko, line.en)}>
                            {line.ko}
                          </span>
                          {index < paragraph.lines.length - 1 && (
                            <span class="hidden sm:inline" aria-hidden="true">
                              {' '}
                            </span>
                          )}
                        </>
                      ))
                    }
                  </p>
                ))
              }
            </div>
          </div>

          <div
            class="relative mx-auto flex w-full max-w-[13rem] items-end justify-center self-stretch sm:max-w-[15.5rem] md:mx-0 md:ml-auto md:max-w-[17rem] lg:max-w-[18rem]"
          >
            <div class="absolute -right-3 bottom-12 hidden h-px w-20 [background-color:color-mix(in_srgb,var(--theme-accent-mark)_36%,var(--theme-border))] md:block"></div>
            <div class="absolute bottom-0 left-1/2 hidden h-[70%] w-px -translate-x-1/2 [background-color:color-mix(in_srgb,var(--theme-border)_72%,transparent)] md:block"></div>
            <img
              src={profileImage}
              alt="당현아 프로필 사진"
              class="relative aspect-[5/7] h-auto max-h-[54svh] w-full object-contain drop-shadow-[0_18px_28px_rgba(21,18,34,0.1)]"
              loading="eager"
              {...i18nAttr('alt', '당현아 프로필 사진', 'Portrait of Dang Hyeona')}
            />
          </div>
        </div>

        <div class="border-t [border-color:var(--theme-border)]">
          <div class="grid grid-cols-2 sm:grid-cols-5">
            {
              hero.activities.map((activity, index) => (
                <div
                  class:list={[
                    'group flex min-h-[5.2rem] flex-col justify-between gap-2 border-b px-3 py-3 text-left transition-colors duration-200 [border-color:var(--theme-border)] hover:[background-color:color-mix(in_srgb,var(--theme-surface-strong)_52%,transparent)] sm:min-h-[6.8rem] sm:border-b-0 sm:border-r sm:px-5 sm:py-4',
                    index === hero.activities.length - 1 && 'sm:border-r-0',
                    index === hero.activities.length - 1 && 'col-span-2 sm:col-span-1'
                  ]}
                >
                  <span class="flex items-center justify-between gap-2">
                    <span class="text-[0.68rem] font-semibold tabular-nums [color:color-mix(in_srgb,var(--theme-accent-mark)_62%,var(--theme-ink-faint))] sm:text-[0.75rem]">
                      {String(index + 1).padStart(2, '0')}
                    </span>
                    <span class="flex size-8 shrink-0 items-center justify-center rounded-md border [border-color:color-mix(in_srgb,var(--theme-border)_88%,transparent)] [color:var(--theme-ink-muted)] transition-colors duration-200 group-hover:[border-color:color-mix(in_srgb,var(--theme-accent-mark)_42%,var(--theme-border))] group-hover:[color:var(--theme-accent-mark)] sm:size-9">
                    {
                      activity.icon === 'code' && (
                        <svg viewBox="0 0 24 24" aria-hidden="true" class="size-4 fill-none stroke-current stroke-[1.8]">
                          <path d="m10 8-4 4 4 4" stroke-linecap="round" stroke-linejoin="round" />
                          <path d="m14 8 4 4-4 4" stroke-linecap="round" stroke-linejoin="round" />
                          <path d="m13 6-2 12" stroke-linecap="round" />
                        </svg>
                      )
                    }
                    {
                      activity.icon === 'book' && (
                        <svg viewBox="0 0 24 24" aria-hidden="true" class="size-4 fill-none stroke-current stroke-[1.8]">
                          <path d="M5 6.5A3.5 3.5 0 0 1 8.5 3H19v15H8.5A3.5 3.5 0 0 0 5 21V6.5Z" stroke-linecap="round" stroke-linejoin="round" />
                          <path d="M5 6.5A3.5 3.5 0 0 1 8.5 3" stroke-linecap="round" />
                          <path d="M9 7h6" stroke-linecap="round" />
                        </svg>
                      )
                    }
                    {
                      activity.icon === 'note' && (
                        <svg viewBox="0 0 24 24" aria-hidden="true" class="size-4 fill-none stroke-current stroke-[1.8]">
                          <path d="M7 4h7l3 3v13H7V4Z" stroke-linecap="round" stroke-linejoin="round" />
                          <path d="M14 4v4h4" stroke-linecap="round" stroke-linejoin="round" />
                          <path d="M10 12h5" stroke-linecap="round" />
                          <path d="M10 16h4" stroke-linecap="round" />
                        </svg>
                      )
                    }
                    {
                      activity.icon === 'nodes' && (
                        <svg viewBox="0 0 24 24" aria-hidden="true" class="size-4 fill-none stroke-current stroke-[1.8]">
                          <path d="M8.5 8.5 15.5 12l-7 3.5" stroke-linecap="round" stroke-linejoin="round" />
                          <circle cx="6.5" cy="7.5" r="2.2" />
                          <circle cx="17.5" cy="12" r="2.2" />
                          <circle cx="6.5" cy="16.5" r="2.2" />
                        </svg>
                      )
                    }
                    {
                      activity.icon === 'heart' && (
                        <svg viewBox="0 0 24 24" aria-hidden="true" class="size-4 fill-none stroke-current stroke-[1.8]">
                          <path d="M12 19s-6.5-3.8-6.5-8.2A3.7 3.7 0 0 1 12 8.3a3.7 3.7 0 0 1 6.5 2.5C18.5 15.2 12 19 12 19Z" stroke-linecap="round" stroke-linejoin="round" />
                        </svg>
                      )
                    }
                    </span>
                  </span>
                  <span
                    class="type-small font-semibold leading-tight [word-break:keep-all] [color:var(--theme-ink-soft)] sm:whitespace-nowrap"
                    {...i18nText(activity.label.ko, activity.label.en)}
                  >
                    {activity.label.ko}
                  </span>
                </div>
              ))
            }
          </div>
        </div>
        </div>
      </div>
    </section>

    <section class="border-y py-14 [background-color:var(--theme-section-branding)] [border-color:var(--theme-border)] sm:py-18 lg:py-20">
      <div class="mx-auto w-full max-w-6xl px-5 sm:px-10 md:px-12 lg:px-20 xl:px-24">
        <div class="mb-8 flex items-center gap-4 sm:mb-10">
          <p class="type-label-wide uppercase [color:var(--theme-accent)]">
            BRANDING WHY
          </p>
          <div class="h-px flex-1 [background-color:var(--theme-border)]"></div>
        </div>

        <div class="grid gap-8 border-t pt-8 [border-color:var(--theme-border)] md:grid-cols-12 md:gap-x-6 md:gap-y-10">
          {
            brandingReasons.map((reason) => (
              <article
                class:list={[
                  'border-l pl-5 [border-color:color-mix(in_srgb,var(--theme-accent-mark)_42%,var(--theme-border))] sm:pl-6',
                  reason.number === '01'
                    ? 'md:col-span-7'
                    : 'md:col-span-7 md:col-start-6 md:-mt-2'
                ]}
              >
                <p class="type-label-wide m-0 [color:var(--theme-accent-mark)]">
                  {reason.number}
                </p>
                <h3
                  class="type-section-title mt-5 max-w-2xl whitespace-pre-line [word-break:keep-all] [color:var(--theme-ink)]"
                  {...i18nText(reason.title.ko, reason.title.en)}
                >
                  {reason.title.ko}
                </h3>
                <div class="type-body mt-6 grid gap-3 [color:var(--theme-ink-muted)]">
                  {reason.paragraphs.map((paragraph) => (
                    <p {...i18nText(paragraph.ko, paragraph.en)}>{paragraph.ko}</p>
                  ))}
                </div>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <section class="py-14 [background-color:var(--theme-section-sites)] sm:py-18 lg:py-20">
      <div class="mx-auto w-full max-w-6xl px-5 sm:px-10 md:px-12 lg:px-20 xl:px-24">
        <div class="border-y py-10 [border-color:var(--theme-border)] sm:py-12">
          <div class="grid gap-5 md:grid-cols-[minmax(0,0.8fr)_minmax(0,1fr)] md:items-end">
            <div>
            <p class="type-label-wide uppercase [color:var(--theme-accent)]">
              {pathwaySection.eyebrow}
            </p>
            <h2
              class="type-section-title mt-5 [word-break:keep-all] [color:var(--theme-ink)]"
            >
              {
                pathwaySection.titleLines.map((line, index) => (
                  <>
                    <span class="block sm:inline" {...i18nText(line.ko, line.en)}>
                      {line.ko}
                    </span>
                    {index < pathwaySection.titleLines.length - 1 && (
                      <span class="hidden sm:inline" aria-hidden="true">
                        {' '}
                      </span>
                    )}
                  </>
                ))
              }
            </h2>
            </div>
            <p
              class="type-small max-w-xl [word-break:keep-all] [color:var(--theme-ink-muted)] md:justify-self-end"
            >
              {
                pathwaySection.descriptionLines.map((line, index) => (
                  <>
                    <span class="block sm:inline" {...i18nText(line.ko, line.en)}>
                      {line.ko}
                    </span>
                    {index < pathwaySection.descriptionLines.length - 1 && (
                      <span class="hidden sm:inline" aria-hidden="true">
                        {' '}
                      </span>
                    )}
                  </>
                ))
              }
            </p>
          </div>

          <div class="mt-12 hidden md:block">
            <div class="relative mx-auto max-w-5xl">
              <div class="relative border-y py-9 [border-color:var(--theme-border)]">
                <div
                  class="pointer-events-none absolute left-8 right-8 top-[3.85rem] h-px [background-color:color-mix(in_srgb,var(--theme-accent-mark)_30%,var(--theme-border))]"
                  aria-hidden="true"
                ></div>
                <div
                  class="pointer-events-none absolute left-0 top-[3.7rem] size-1.5 rounded-full [background-color:var(--theme-accent-mark)]"
                  aria-hidden="true"
                ></div>
                <div
                  class="pointer-events-none absolute right-0 top-[3.7rem] h-16 w-12 rounded-br-lg border-b border-r [border-color:color-mix(in_srgb,var(--theme-accent-mark)_30%,var(--theme-border))]"
                  aria-hidden="true"
                ></div>

                <div class="relative grid grid-cols-4">
                {
                  pathwayItems.map((item) => (
                    <a
                      href={item.disabled ? undefined : item.href}
                      class:list={[
                        'group relative flex min-h-[13.25rem] flex-col items-center px-4 text-center no-underline transition-colors duration-200',
                        item.disabled && 'cursor-default opacity-[0.78]'
                      ]}
                      data-hub-pathway-link={item.icon}
                      data-resume-modal-trigger={item.icon === 'resume' ? '' : undefined}
                      aria-haspopup={item.icon === 'resume' ? 'dialog' : undefined}
                      aria-controls={item.icon === 'resume' ? 'resume-choice-modal' : undefined}
                      aria-disabled={item.disabled ? 'true' : undefined}
                    >
                      <span class="relative z-10 flex size-14 items-center justify-center rounded-md border [border-color:var(--theme-border)] [background-color:var(--theme-section-sites)] [box-shadow:0_0_0_10px_var(--theme-section-sites)] [color:var(--theme-ink-muted)] transition-colors duration-200 group-hover:[border-color:color-mix(in_srgb,var(--theme-accent-mark)_44%,var(--theme-border))] group-hover:[color:var(--theme-accent-mark)]">
                          {
                            item.icon === 'resume' && (
                              <svg viewBox="0 0 24 24" aria-hidden="true" class="size-5 fill-none stroke-current stroke-[1.7]">
                                <path d="M7 4h7l3 3v13H7V4Z" stroke-linecap="round" stroke-linejoin="round" />
                                <path d="M14 4v4h4" stroke-linecap="round" stroke-linejoin="round" />
                                <path d="M10 12h4" stroke-linecap="round" />
                                <path d="M10 16h5" stroke-linecap="round" />
                              </svg>
                            )
                          }
                          {
                            item.icon === 'portfolio' && (
                              <svg viewBox="0 0 24 24" aria-hidden="true" class="size-5 fill-none stroke-current stroke-[1.7]">
                                <path d="M6 8h12v11H6V8Z" stroke-linecap="round" stroke-linejoin="round" />
                                <path d="M9 8V6.5A2.5 2.5 0 0 1 11.5 4h1A2.5 2.5 0 0 1 15 6.5V8" stroke-linecap="round" />
                                <path d="M9 13h6" stroke-linecap="round" />
                              </svg>
                            )
                          }
                          {
                            item.icon === 'experience' && (
                              <svg viewBox="0 0 24 24" aria-hidden="true" class="size-5 fill-none stroke-current stroke-[1.7]">
                                <path d="M7 4h10v16l-5-3-5 3V4Z" stroke-linecap="round" stroke-linejoin="round" />
                              </svg>
                            )
                          }
                          {
                            item.icon === 'blog' && (
                              <svg viewBox="0 0 24 24" aria-hidden="true" class="size-5 fill-none stroke-current stroke-[1.7]">
                                <path d="M15.5 5.5 18.5 8.5 10 17l-4 1 1-4 8.5-8.5Z" stroke-linecap="round" stroke-linejoin="round" />
                                <path d="m14 7 3 3" stroke-linecap="round" />
                              </svg>
                            )
                          }
                        </span>

                      <span class="type-caption mt-8 font-semibold tabular-nums [color:var(--theme-ink-faint)]">
