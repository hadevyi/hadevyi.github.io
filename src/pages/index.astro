  <div
    id="resume-choice-modal"
    class="fixed inset-0 z-[80] hidden items-center justify-center px-5 py-8"
    data-resume-modal
    aria-hidden="true"
  >
    <button
      type="button"
      class="absolute inset-0 [background-color:color-mix(in_srgb,var(--theme-ink)_22%,transparent)] backdrop-blur-[6px]"
      data-resume-modal-close
      {...i18nAttr('aria-label', '이력서 선택 창 닫기', 'Close resume chooser')}
    ></button>

    <section
      role="dialog"
      aria-modal="true"
      aria-labelledby="resume-choice-title"
      aria-describedby="resume-choice-description"
      class="relative w-full max-w-[25rem] rounded-[1.25rem] border p-5 [border-color:var(--theme-border)] [background-color:var(--theme-surface-strong)] [box-shadow:0_20px_64px_rgba(17,16,26,0.22)]"
    >
      <div class="flex items-start justify-between gap-5 border-b pb-4 [border-color:var(--theme-border)]">
        <div class="min-w-0">
          <h2
            id="resume-choice-title"
            class="type-card-title [color:var(--theme-ink)]"
            {...i18nText('이력서 선택', 'Choose Resume')}
          >
            이력서 선택
          </h2>
          <p
            id="resume-choice-description"
            class="type-caption mt-1.5 [word-break:keep-all] [color:var(--theme-ink-muted)]"
            {...i18nText(
              '확인할 이력서와 언어를 선택해주세요.',
              'Select a resume type and language.'
            )}
          >
            확인할 이력서와 언어를 선택해주세요.
          </p>
        </div>
        <button
          type="button"
          class="flex size-9 shrink-0 items-center justify-center rounded-full border [border-color:var(--theme-border)] [background-color:color-mix(in_srgb,var(--theme-surface)_82%,transparent)] [color:var(--theme-ink-muted)] transition-colors duration-200 hover:[color:var(--theme-accent)]"
          data-resume-modal-close
          {...i18nAttr('aria-label', '이력서 선택 창 닫기', 'Close resume chooser')}
        >
          <svg viewBox="0 0 24 24" aria-hidden="true" class="size-4 fill-none stroke-current stroke-[1.8]">
            <path d="m7 7 10 10" stroke-linecap="round" />
            <path d="M17 7 7 17" stroke-linecap="round" />
          </svg>
        </button>
      </div>

      <div class="mt-4 space-y-2.5">
        {
          resumeOptions.map((group) => (
            <div class="grid grid-cols-3 items-center gap-2 rounded-[0.9rem] border px-3 py-2.5 [border-color:var(--theme-border)] [background-color:color-mix(in_srgb,var(--theme-surface)_60%,transparent)]">
              <span
                class="type-small text-center font-semibold [color:var(--theme-ink)]"
                {...i18nText(group.role.ko, group.role.en)}
              >
                {group.role.ko}
              </span>
              <>
                {group.options.map((option) => (
                  <a
                    href={option.href}
                    class="rounded-full border px-3 py-2 text-center text-sm font-semibold no-underline transition-colors duration-200 [border-color:var(--theme-border)] [color:var(--theme-accent)] hover:[border-color:color-mix(in_srgb,var(--theme-accent)_48%,var(--theme-border))] hover:[background-color:color-mix(in_srgb,var(--theme-accent)_8%,transparent)]"
                    data-resume-option
                    data-resume-type={group.type}
                    data-resume-language={option.language}
                    {...i18nText(option.label.ko, option.label.en)}
                  >
                    {option.label.ko}
                  </a>
                ))}
              </>
            </div>
          ))
        }
      </div>
    </section>
  </div>

  <script is:inline>
    (() => {
      const modal = document.querySelector('[data-resume-modal]');
      if (!modal) return;

      const triggers = document.querySelectorAll('[data-resume-modal-trigger]');
      const closeControls = modal.querySelectorAll('[data-resume-modal-close]');
      const firstCloseControl = closeControls[closeControls.length - 1];
      let previousFocus = null;
      const trackEvent = (eventName, params = {}) => {
        if (typeof window.hadevyiTrackEvent === 'function') {
          window.hadevyiTrackEvent(eventName, params);
        }
      };

      const getFocusableItems = () => Array.from(
        modal.querySelectorAll('a[href], button:not([disabled])')
      );

      const openModal = (event) => {
        event.preventDefault();
        previousFocus = document.activeElement;
        modal.classList.remove('hidden');
        modal.classList.add('flex');
        modal.setAttribute('aria-hidden', 'false');
        document.body.style.overflow = 'hidden';
        trackEvent('resume_modal_open', { source: 'main_hub' });
        firstCloseControl?.focus();
      };

      const closeModal = () => {
        modal.classList.add('hidden');
        modal.classList.remove('flex');
        modal.setAttribute('aria-hidden', 'true');
        document.body.style.overflow = '';

        if (previousFocus instanceof HTMLElement) {
          previousFocus.focus();
        }
      };

      triggers.forEach((trigger) => {
        trigger.addEventListener('click', openModal);
      });

      closeControls.forEach((control) => {
        control.addEventListener('click', closeModal);
      });

      modal.querySelectorAll('[data-resume-option]').forEach((link) => {
        link.addEventListener('click', () => {
          trackEvent('resume_select', {
            resume_type: link.getAttribute('data-resume-type') || '',
            language: link.getAttribute('data-resume-language') || ''
          });
        });
      });

      document.querySelectorAll('[data-hub-pathway-link]').forEach((link) => {
        link.addEventListener('click', () => {
          const target = link.getAttribute('data-hub-pathway-link') || '';
          const isDisabled = link.getAttribute('aria-disabled') === 'true';

          if (!target || target === 'resume' || isDisabled) return;

          trackEvent('hub_navigation_click', { target });
        });
      });

      document.querySelectorAll('[data-hub-contact-link]').forEach((link) => {
        link.addEventListener('click', () => {
          trackEvent('hub_contact_click', {
            link_type: link.getAttribute('data-hub-contact-link') || ''
          });
        });
      });

      document.addEventListener('keydown', (event) => {
        if (modal.getAttribute('aria-hidden') === 'true') return;

        if (event.key === 'Escape') {
          closeModal();
          return;
        }

        if (event.key !== 'Tab') return;

        const focusableItems = getFocusableItems();
        const firstItem = focusableItems[0];
        const lastItem = focusableItems[focusableItems.length - 1];

        if (!firstItem || !lastItem) return;

        if (event.shiftKey && document.activeElement === firstItem) {
          event.preventDefault();
          lastItem.focus();
        } else if (!event.shiftKey && document.activeElement === lastItem) {
          event.preventDefault();
          firstItem.focus();
        }
      });
    })();
  </script>
</BaseLayout>
