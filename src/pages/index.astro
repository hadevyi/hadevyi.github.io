                              <path d="M7 4h10v16H7V4Z" stroke-linecap="round" stroke-linejoin="round" />
                              <path d="M10 8h4" stroke-linecap="round" />
                              <path d="M10 12h4" stroke-linecap="round" />
                              <path d="M10 16h2.5" stroke-linecap="round" />
