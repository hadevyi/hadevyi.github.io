                      </span>
                      <span class="min-w-0 flex-1">
                        <span
                          class="type-small block font-semibold [color:var(--theme-ink)]"
                          {...i18nText(link.label.ko, link.label.en)}
                        >
                          {link.label.ko}
                        </span>
                        <span
                          class="type-caption block [word-break:keep-all] [color:var(--theme-ink-muted)]"
                          {...i18nText(link.description.ko, link.description.en)}
                        >
                          {link.description.ko}
