---
import BaseLayout from '../layouts/BaseLayout.astro';
import { siteMeta } from '../data/site';
---

<BaseLayout title="페이지를 찾을 수 없음" description="요청한 페이지를 찾지 못했습니다.">
  <section class="surface-card p-10 text-center">
    <p class="eyebrow">404</p>
    <h1 class="type-display mt-5 text-ink">페이지를 찾을 수 없습니다</h1>
    <p class="type-body mx-auto mt-4 max-w-xl text-ink/72">
      링크가 바뀌었거나 아직 준비되지 않은 페이지일 수 있어요. 메인 홈페이지에서 다시 탐색해보세요.
    </p>
    <a
      href={siteMeta.rootPath}
      class="button-primary type-small mt-8 px-5 py-3"
    >
      홈으로 돌아가기
    </a>
  </section>
</BaseLayout>
